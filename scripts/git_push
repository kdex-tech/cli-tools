#!/bin/sh

set -e

# Same safe.directory exemption as git_checkout — each init container has
# its own /tmp so we must set it again here. See git_checkout for the
# rationale.
export GIT_CONFIG_GLOBAL="${GIT_CONFIG_GLOBAL:-/tmp/codegen-gitconfig}"
printf '[safe]\n\tdirectory = *\n' > "${GIT_CONFIG_GLOBAL}"

cd "${WORKDIR}"
source .env

cd "${TARGET_DIR}"
echo "${FUNCTION_SPEC}" > function.yaml
cd -

# 1. Commit and Push
git add "${TARGET_DIR}"
if git diff-index --quiet HEAD; then
  echo "No changes detected for this iteration."
else
  git commit -m "Update function: ${FUNCTION_HOST}/${FUNCTION_NAME}:${FUNCTION_GENERATION}"
  git push origin "${BRANCH_NAME}"
fi
